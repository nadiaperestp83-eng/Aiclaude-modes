# Environment files (API keys)
.env
.env.*

# Context init file (regenerated each session)
.claude/.context-init.md

# Local settings (user-specific; may contain API keys in permission rules)
.claude/settings.local.json

# Session state (user-specific)
.claude/session-cache.json
.claude/claude-state.json
.claude/claude-progress.md
.claude/sync-cache.json
.claude/canvas/

# Runtime artefacts (must never be tracked)
.claude/scheduled_tasks.lock
.claude/worktrees/

# Backup files
*.bak
*~

# Windows artifacts
nul
Thumbs.db

# macOS artifacts
.DS_Store

# Temporary files
*.tmp
*.temp

# Scraped/generated data
*_scraped.json
*_scraped.csv
.grok/

# Test artifacts
tests/*/output/
